# "Generate Widget" (the sparkle bubble) needs an OpenAI key. Copy this file
# to .env for local dev; on Netlify set the same variables in the site env.
OPENAI_API_KEY=sk-...
# Optional — defaults to gpt-5-mini.
# OPENAI_MODEL=gpt-5
# Optional — defaults to "low" (keeps generation inside Netlify's ~26s
# synchronous function timeout; "medium" produced 60s+ generations).
# OPENAI_REASONING_EFFORT=low
